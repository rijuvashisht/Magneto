{
  "name": "magneto-ai",
  "version": "0.12.0",
  "description": "Repo-local AI reasoning framework and agent control plane for enterprise environments",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "magneto": "dist/cli.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:pack": "npm pack --dry-run 2>&1 | head -50",
    "prepare": "npm run build",
    "prerelease": "npm run build && npm test && npm run test:pack",
    "release:patch": "npm run prerelease && npm version patch && git push origin HEAD --tags",
    "release:minor": "npm run prerelease && npm version minor && git push origin HEAD --tags",
    "release:major": "npm run prerelease && npm version major && git push origin HEAD --tags",
    "changelog:check": "node scripts/check-changelog.js",
    "version:check": "node scripts/check-breaking-changes.js",
    "docs:build": "echo 'Building documentation...' && npm run changelog:check"
  },
  "keywords": [
    "ai",
    "reasoning",
    "agent",
    "orchestrator",
    "copilot",
    "openai",
    "mcp",
    "enterprise",
    "security",
    "multi-agent"
  ],
  "author": "Riju Vashisht",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rijuvashisht/Magneto.git"
  },
  "homepage": "https://github.com/rijuvashisht/Magneto#readme",
  "bugs": {
    "url": "https://github.com/rijuvashisht/Magneto/issues"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "glob": "^10.3.10",
    "jsonschema": "^1.4.1",
    "magneto": "^0.4.1",
    "magneto-ai": "^0.1.4",
    "openai": "^4.52.0",
    "uuid": "^9.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "src/templates/",
    "scripts/postinstall.js",
    "docs/",
    "examples/",
    "README.md",
    "CHANGELOG.md",
    "BREAKING_CHANGES.md",
    "LICENSE"
  ]
}
